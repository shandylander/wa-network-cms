rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Email format: wa001@wanetwork.cms (Firebase lowercases emails) → "WA001"
    // Storage rules CAN read Firestore (firestore.get), so we derive the
    // caller's app userId from their auth email and look up their role —
    // mirrors the uid()/me() helpers in firestore.rules.
    function callerId() {
      return request.auth.token.email.split('@')[0].upper();
    }
    function callerRole() {
      return firestore.get(/databases/(default)/documents/users/$(callerId())).data.role;
    }
    function isInternal() {
      return callerRole() in ['owner', 'manager', 'supervisor'];
    }
    function callerTeam() {
      return firestore.get(/databases/(default)/documents/users/$(callerId())).data.team;
    }
    // Mirrors firestore.rules' assignedToProject() for the sitePhotos
    // Firestore doc rule — a subcon can only touch a project's photo blobs
    // if their team is actually assigned to that project.
    function assignedToProject(projectId) {
      return firestore.get(/databases/(default)/documents/projects/$(projectId)).data.assignedTeams.hasAny([callerTeam()]);
    }

    // Attendance selfies — authenticated users can write their own folder;
    // owner/manager/supervisor can read all (PhotoReview/ApprovalQueue/audit
    // screens), everyone else only their own.
    match /attendance/{userId}/{date}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 5 * 1024 * 1024   // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Medical certificates — photo or PDF, uploaded by workers applying MC leave.
    match /mc/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Worker certificates — photo or PDF, keyed by uploader.
    match /certs/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Worker profile photos — optional, uploaded by an admin from Worker
    // Modal. Same shape as certs/ (keyed by uploader), returned download URL
    // is what's actually stored on workers/{id}.photoUrl and rendered.
    match /avatars/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId() && isInternal()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Petty cash receipts — photo or PDF.
    match /receipts/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Delivery order scans — captured by internal roles (owner/manager/
    // supervisor) or staff granted materials:submit-do, when logging a DO
    // in the Materials tab; matches the deliveryOrders Firestore rule.
    // Same self-scoped shape as receipts/{userId} — no isInternal() gate.
    match /deliveryOrders/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Site progress photos — mirrors firestore.rules' projects/{id}/sitePhotos
    // doc rule (anyStaff() || assigned subcon). Never had a match block here,
    // so every upload (camera capture or the Upload Photo fallback) and every
    // read of an existing photo was silently denied.
    match /sitePhotos/{projectId}/{fileName} {
      allow read: if request.auth != null && (
        isInternal() || callerRole() == 'staff'
        || (callerRole() in ['subcon-admin', 'subcon'] && assignedToProject(projectId))
      );
      allow write: if request.auth != null && (
        isInternal() || callerRole() == 'staff'
        || (callerRole() in ['subcon-admin', 'subcon'] && assignedToProject(projectId))
      )
      && request.resource.size < 8 * 1024 * 1024
      && request.resource.contentType.matches('image/.*');
    }

    // Snag/defect evidence photos — same scoping as the snags Firestore rule
    // (anyStaff() || assigned subcon can read/attach; anyone who can report a
    // defect can also photograph it).
    match /snagPhotos/{projectId}/{fileName} {
      allow read: if request.auth != null && (
        isInternal() || callerRole() == 'staff'
        || (callerRole() in ['subcon-admin', 'subcon'] && assignedToProject(projectId))
      );
      allow write: if request.auth != null && (
        isInternal() || callerRole() == 'staff'
        || (callerRole() in ['subcon-admin', 'subcon'] && assignedToProject(projectId))
      )
      && request.resource.size < 8 * 1024 * 1024
      && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
