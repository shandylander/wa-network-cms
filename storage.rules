rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Attendance selfies — authenticated users can write their own folder,
    // managers/owners can read all (enforced at app level, not storage level
    // since we can't check Firestore roles from Storage rules easily).
    // All authenticated users can read (photos are accessed via download URL).
    match /attendance/{userId}/{date}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024   // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
