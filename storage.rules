rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Email format: wa001@wanetwork.cms (Firebase lowercases emails) → "WA001"
    // Storage rules CAN read Firestore (firestore.get), so we derive the
    // caller's app userId from their auth email and look up their role —
    // mirrors the uid()/me() helpers in firestore.rules.
    function callerId() {
      return request.auth.token.email.split('@')[0].upper();
    }
    function callerRole() {
      return firestore.get(/databases/(default)/documents/users/$(callerId())).data.role;
    }
    function isInternal() {
      return callerRole() in ['owner', 'manager', 'supervisor'];
    }

    // Attendance selfies — authenticated users can write their own folder;
    // owner/manager/supervisor can read all (PhotoReview/ApprovalQueue/audit
    // screens), everyone else only their own.
    match /attendance/{userId}/{date}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 5 * 1024 * 1024   // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Medical certificates — photo or PDF, uploaded by workers applying MC leave.
    match /mc/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Worker certificates — photo or PDF, keyed by uploader.
    match /certs/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Petty cash receipts — photo or PDF.
    match /receipts/{userId}/{fileName} {
      allow read:  if request.auth != null && (userId == callerId() || isInternal());
      allow write: if request.auth != null && userId == callerId()
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
