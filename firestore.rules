rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Email format: wa001@wanetwork.cms (Firebase lowercases emails) → "WA001"
    function uid() {
      return request.auth.token.email.split('@')[0].upper();
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function signedIn()     { return request.auth != null; }
    function isOwner()      { return signedIn() && me().role == 'owner'; }
    function isManager()    { return signedIn() && me().role == 'manager'; }
    function isSupervisor() { return signedIn() && me().role == 'supervisor'; }
    function isStaff()      { return signedIn() && me().role == 'staff'; }
    function isSubconAdmin(){ return signedIn() && me().role == 'subcon-admin'; }
    function isSubcon()     { return signedIn() && me().role == 'subcon'; }
    function myTeam()       { return me().team; }

    function ownerOrManager() { return isOwner() || isManager(); }
    function internal()       { return isOwner() || isManager() || isSupervisor(); }
    function anyStaff()       { return internal() || isStaff(); }

    // ── BOOTSTRAP ─────────────────────────────────────────────────────────
    // Allow all reads/writes before first-time setup is complete.
    // Once _metadata/setup is written, this rule never matches again.
    match /{document=**} {
      allow read, write: if !exists(/databases/$(database)/documents/_metadata/setup);
    }

    // _metadata is always publicly readable (setup page checks it on load)
    match /_metadata/{docId} {
      allow read:  if true;
      allow write: if ownerOrManager()
        || !exists(/databases/$(database)/documents/_metadata/setup);
    }

    // ── USERS ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if signedIn() && (
        uid() == userId || ownerOrManager() || isSupervisor()
      );
      // effectivePermissions is Cloud-Function-only, never client-writable —
      // it's the denormalized result Access Levels compute server-side.
      allow create: if ownerOrManager()
        && !('effectivePermissions' in request.resource.data);
      allow update: if (
        isOwner()
        || (isManager()     && resource.data.role != 'owner')
        || (isSubconAdmin() && resource.data.team == myTeam())
        // users may flip their own firstLogin flag during forced PIN change
        || (uid() == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firstLogin']))
      )
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['effectivePermissions'])
        // role/accessLevels assignment is never delegable — owner/manager only,
        // regardless of which branch above would otherwise permit the write.
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'accessLevels']) || ownerOrManager());
      allow delete: if isOwner();
    }

    // ── PROJECTS ───────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if signedIn() && (
        anyStaff() ||
        ((isSubconAdmin() || isSubcon()) && resource.data.assignedTeams.hasAny([myTeam()]))
      );
      allow create: if ownerOrManager();
      allow update: if ownerOrManager() || isSupervisor();
      allow delete: if isOwner();

      // Blocks
      match /blocks/{blockId} {
        allow read: if signedIn() && (
          anyStaff() ||
          ((isSubconAdmin() || isSubcon()) && resource.data.team == myTeam())
        );
        allow create: if ownerOrManager();
        allow update: if ownerOrManager() || isSupervisor()
          || ((isStaff() || isSubconAdmin() || isSubcon()) && resource.data.team == myTeam());
        allow delete: if ownerOrManager();
      }

      // Documents — default no access; access granted per team flag
      match /documents/{docId} {
        allow read: if signedIn() && (
          internal() ||
          (isStaff()       && resource.data.access.get('own',    false)) ||
          (isSubconAdmin() && resource.data.access.get(myTeam(), false)) ||
          (isSubcon()      && resource.data.access.get(myTeam(), false))
        );
        allow write: if ownerOrManager();
      }

      // Claims / finance — owner + manager only
      match /claims/{id}         { allow read, write: if ownerOrManager(); }
      match /materialOrders/{id} { allow read, write: if ownerOrManager() || isSupervisor(); }
      match /deliveryOrders/{id} { allow read, write: if ownerOrManager() || isSupervisor(); }
      match /materials/{id}      { allow read, write: if ownerOrManager() || isSupervisor(); }

      // HSE / site subcollections — internal + assigned subcons
      function assignedToProject(pid) {
        return get(/databases/$(database)/documents/projects/$(pid)).data.assignedTeams.hasAny([myTeam()]);
      }
      match /permits/{id} {
        allow read:  if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
        allow write: if internal();
      }
      match /toolboxMeetings/{id} {
        allow read:  if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
        allow write: if internal();
      }
      match /incidents/{id}  { allow read, write: if anyStaff(); }
      // Snags are directed to the sub-con team handling the block, so an
      // assigned sub-con may read/log/update snags for their own team only.
      match /snags/{id} {
        allow read:   if anyStaff()
          || ((isSubconAdmin() || isSubcon()) && resource.data.assignedTeam == myTeam());
        allow create: if anyStaff()
          || ((isSubconAdmin() || isSubcon()) && request.resource.data.assignedTeam == myTeam());
        allow update: if anyStaff()
          || ((isSubconAdmin() || isSubcon()) && resource.data.assignedTeam == myTeam());
        allow delete: if ownerOrManager();
      }
      match /sitePhotos/{id} {
        allow read:  if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
        allow write: if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
      }
    }

    // ── WORKERS ────────────────────────────────────────────────────────────
    match /workers/{workerId} {
      allow read: if signedIn() && (
        ownerOrManager() || isSupervisor() ||
        (isSubconAdmin() && resource.data.team == myTeam())
      );
      allow create: if ownerOrManager()
        || (isSubconAdmin() && request.resource.data.team == myTeam());
      allow update: if ownerOrManager()
        || (isSubconAdmin() && resource.data.team == myTeam());
      allow delete: if ownerOrManager();
    }

    // ── ANNOUNCEMENTS ──────────────────────────────────────────────────────
    match /announcements/{annId} {
      allow read: if signedIn();
      // Owner/manager can post anything; signed-in users can post system
      // notifications (leave requests etc.) targeted to management only
      allow create: if ownerOrManager()
        || (signedIn()
            && request.resource.data.isSystemNotification == true
            && request.resource.data.audience == 'management');
      allow update: if ownerOrManager()
        // Any signed-in user may add their own userId to readBy (acknowledge)
        || (signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
      allow delete: if ownerOrManager();
    }

    // ── RA LIBRARY ─────────────────────────────────────────────────────────
    match /raLibrary/{raId} {
      allow read:  if signedIn();
      allow write: if ownerOrManager();
    }

    // ── APP CONFIG (team groups, certificate types) ────────────────────────
    match /appConfig/{docId} {
      allow read:  if signedIn();
      allow write: if ownerOrManager();
    }

    // ── ACCESS LEVELS ──────────────────────────────────────────────────────
    // Defining/editing levels is never delegable via the permission system
    // itself — hard-coded owner/manager only, to prevent self-escalation
    // (someone with a grantable "manage access levels" permission could
    // otherwise grant themselves anything). Do not convert this to hasPerm().
    match /accessLevels/{levelId} {
      allow read:  if signedIn();
      allow write: if ownerOrManager();
    }

    // ── ATTENDANCE ─────────────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read: if signedIn() && (
        ownerOrManager() || isSupervisor() ||
        (isStaff()       && resource.data.userId == uid()) ||
        (isSubconAdmin() && resource.data.team   == myTeam()) ||
        (isSubcon()      && resource.data.userId == uid())
      );
      allow create: if signedIn() && (request.resource.data.userId == uid() || ownerOrManager());
      allow update: if ownerOrManager() || isSupervisor()
        || resource.data.userId == uid();
      allow delete: if ownerOrManager();
    }

    // ── LEAVE ──────────────────────────────────────────────────────────────
    match /leaveApplications/{id} {
      allow read: if signedIn() && (
        ownerOrManager() || isSupervisor() || resource.data.userId == uid()
      );
      allow create: if signedIn() && (request.resource.data.userId == uid() || ownerOrManager());
      // Applicants may edit or cancel their own application while pending,
      // but cannot change its owner or self-approve it.
      allow update: if ownerOrManager() || isSupervisor()
        || (resource.data.userId == uid()
            && resource.data.status == 'pending'
            && request.resource.data.status in ['pending', 'cancelled']
            && request.resource.data.userId == resource.data.userId);
      allow delete: if ownerOrManager();
    }
    match /leaveEntitlements/{id} {
      allow read: if signedIn() && (
        ownerOrManager() || isSupervisor() || resource.data.userId == uid()
      );
      allow write: if ownerOrManager();
    }

    // ── PAYROLL ────────────────────────────────────────────────────────────
    match /payslips/{id} {
      allow read:  if ownerOrManager() || resource.data.userId == uid();
      allow write: if ownerOrManager();
    }
    match /salaryConfig/{id} {
      allow read, write: if ownerOrManager();
    }
    match /pettyCashClaims/{id} {
      allow read: if ownerOrManager() || isSupervisor()
        || resource.data.userId == uid();
      allow create: if signedIn() && (request.resource.data.userId == uid() || ownerOrManager());
      // Submitters may correct their own claim while it is still pending,
      // but cannot change its owner or self-approve it.
      allow update: if ownerOrManager()
        || (resource.data.userId == uid()
            && resource.data.status == 'pending'
            && request.resource.data.status == 'pending'
            && request.resource.data.userId == resource.data.userId);
      allow delete: if ownerOrManager();
    }
  }
}
