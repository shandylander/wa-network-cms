rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Email format: wa001@wanetwork.cms (Firebase lowercases emails) → "WA001"
    function uid() {
      return request.auth.token.email.split('@')[0].upper();
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function signedIn()     { return request.auth != null; }
    function isOwner()      { return signedIn() && me().role == 'owner'; }
    function isManager()    { return signedIn() && me().role == 'manager'; }
    function isSupervisor() { return signedIn() && me().role == 'supervisor'; }
    function isStaff()      { return signedIn() && me().role == 'staff'; }
    function isSubconAdmin(){ return signedIn() && me().role == 'subcon-admin'; }
    function isSubcon()     { return signedIn() && me().role == 'subcon'; }
    function myTeam()       { return me().team; }

    function ownerOrManager() { return isOwner() || isManager(); }
    function internal()       { return isOwner() || isManager() || isSupervisor(); }
    function anyStaff()       { return internal() || isStaff(); }

    // Access Levels — see accessLevels/{levelId} below. Only used for
    // conditions that are clean, standalone feature gates with a verified
    // exact match in src/utils/permissionCatalog.js's default role-sets.
    // Do NOT use for conditions structurally tied to Bucket-B team/self
    // scoping, or where no catalog key reproduces today's exact role-set —
    // those stay on the role helpers above until a follow-up pass resolves
    // the mismatch deliberately rather than silently.
    function hasPerm(p) { return p in me().effectivePermissions; }

    // ── SETUP SENTINEL ────────────────────────────────────────────────────
    // The pre-setup bootstrap rule (full read/write while _metadata/setup
    // didn't exist) has been retired: setup is complete in production, and
    // keeping it meant a single sentinel delete would re-open the entire
    // database to unauthenticated clients. The sentinel is now undeletable;
    // re-running initial setup requires temporarily relaxing rules on
    // purpose, not an accidental door.
    match /_metadata/{docId} {
      allow read:   if true;
      allow create, update: if ownerOrManager();
      allow delete: if false;
    }

    // ── USERS ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if signedIn() && (
        uid() == userId || ownerOrManager() || isSupervisor()
      );
      // effectivePermissions is Cloud-Function-only, never client-writable —
      // it's the denormalized result Access Levels compute server-side.
      allow create: if ownerOrManager()
        && !('effectivePermissions' in request.resource.data);
      allow update: if (
        isOwner()
        || (isManager()     && resource.data.role != 'owner')
        // team is immutable from this branch — otherwise a subcon-admin
        // could re-team themselves (or a teammate) into another
        // subcontractor's data scope.
        || (isSubconAdmin() && resource.data.team == myTeam()
            && request.resource.data.team == resource.data.team)
        // users may flip their own firstLogin flag during forced PIN change,
        // stamp pinLength during the one-time 4→6 PIN upgrade, and manage
        // their own device push-notification tokens
        || (uid() == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firstLogin', 'fcmTokens', 'pinLength']))
      )
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['effectivePermissions'])
        // pinLength only ever moves to 6 — no branch may downgrade it back
        // to a 4-digit marker.
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['pinLength']) || request.resource.data.pinLength == 6)
        // role/accessLevels assignment is never delegable — owner/manager only,
        // regardless of which branch above would otherwise permit the write.
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'accessLevels']) || ownerOrManager());
      allow delete: if isOwner();
    }

    // ── CUSTOMERS ──────────────────────────────────────────────────────────
    // Internal-only — contact details and warranty/dispute notes are not
    // something sub-cons should ever see.
    match /customers/{customerId} {
      allow read, write: if hasPerm('manage:customers');

      // Reference docs (floorplans, drawings, tech docs) for this customer's
      // site — read-only for technicians so they can pull them up during a
      // job; upload/manage stays with whoever manages the Customer record.
      match /documents/{docId} {
        allow read:  if hasPerm('manage:customers') || hasPerm('manage:service-reports');
        allow write: if hasPerm('manage:customers');
      }
    }

    // ── SERVICE REPORTS ────────────────────────────────────────────────────
    // ── SERVICE JOBS ─────────────────────────────────────────────────────
    // Renamed from serviceReports — now a full job lifecycle (scheduled →
    // in-progress → completed → vetted), not just a post-visit report.
    // `manage:service-reports` is the base technician permission (kept as
    // the original key string so the existing Owner grant stays valid);
    // `jobs:assign` schedules/reassigns, `jobs:vet` reviews a finished job.
    match /serviceJobs/{jobId} {
      // Self-scoped read lets an assigned technician see their own job even
      // if they don't hold the broader manage:service-reports grant — this
      // is what WorkerHome's "assignedTo array-contains me" query relies on.
      allow read: if hasPerm('manage:service-reports') || hasPerm('jobs:assign') || hasPerm('jobs:vet')
        || ('assignedTo' in resource.data && uid() in resource.data.assignedTo);

      // Manager scheduling a job ahead of time, or a technician self-
      // creating an ad-hoc job (must list themselves in assignedTo). A
      // self-created job may start scheduled/in-progress/completed (the
      // ad-hoc flow completes on the spot) but can't be born already vetted —
      // vetting is a jobs:vet decision, never something the creator stamps on
      // themselves.
      allow create: if hasPerm('jobs:assign')
        || (hasPerm('manage:service-reports')
            && uid() in request.resource.data.assignedTo
            && request.resource.data.status in ['scheduled', 'in-progress', 'completed']
            && request.resource.data.vettedBy == null);

      // Any assigned technician can drive their own job through
      // scheduled → in-progress → completed (check in/out, add photos,
      // submit the report) but cannot touch assignment or vet fields —
      // those need jobs:assign / jobs:vet respectively.
      allow update: if hasPerm('jobs:assign')
        || hasPerm('jobs:vet')
        || (hasPerm('manage:service-reports')
            && uid() in resource.data.assignedTo
            && request.resource.data.status in ['in-progress', 'completed']
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['assignedTo', 'assignedToNames', 'assignedBy', 'vettedBy', 'vettedByName', 'vettedAt']));

      allow delete: if hasPerm('jobs:assign');
    }

    // ── PROJECTS ───────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if signedIn() && (
        anyStaff() ||
        ((isSubconAdmin() || isSubcon()) && resource.data.assignedTeams.hasAny([myTeam()]))
      );
      // create: matches ProjectList.jsx's existing manage:blocks gate exactly
      allow create: if hasPerm('manage:blocks');
      // update: role-component intentionally left unconverted — the current
      // rule (ownerOrManager()||isSupervisor()) doesn't exactly match any
      // single catalog permission's role-set without either narrowing
      // supervisor out (regression) or widening a narrower key (over-grant).
      allow update: if ownerOrManager() || isSupervisor();
      // deleteProtected (set via Edit Project, owner-only in the UI) blocks
      // deletion at the backend too — not just a hidden button — so a
      // project like PCS Batch 3 can't be removed even via direct API
      // calls once flagged. Only isOwner() can delete at all in the first
      // place, so this only needs to check the resource, not who's asking.
      allow delete: if isOwner() && !resource.data.get('deleteProtected', false);

      // Blocks
      match /blocks/{blockId} {
        // read: left unconverted — anyStaff() here is structurally paired
        // with the subcon team-scoped branch; converting the broad side to
        // a permission key that subcon-admin/subcon's own level also grants
        // (per the wider app-level view:projects permission) would silently
        // remove their team-scoping. Needs a deliberate follow-up decision,
        // not a mechanical conversion.
        allow read: if signedIn() && (
          anyStaff() ||
          ((isSubconAdmin() || isSubcon()) && resource.data.team == myTeam())
        );
        allow create: if hasPerm('manage:blocks');
        allow update: if ownerOrManager() || isSupervisor()
          || ((isStaff() || isSubconAdmin() || isSubcon()) && resource.data.team == myTeam());
        allow delete: if hasPerm('blocks:delete');
      }

      // Documents — default no access; access granted per team flag
      match /documents/{docId} {
        // read: left unconverted, same reasoning as blocks read above.
        allow read: if signedIn() && (
          internal() ||
          (isStaff()       && resource.data.access.get('own',    false)) ||
          (isSubconAdmin() && resource.data.access.get(myTeam(), false)) ||
          (isSubcon()      && resource.data.access.get(myTeam(), false))
        );
        // write: matches ProjectDocuments.jsx's existing manage:blocks gate
        allow write: if hasPerm('manage:blocks');
      }

      // Claims / finance — owner + manager only, no subcon involvement
      match /claims/{id}         { allow read, write: if hasPerm('view:claims'); }
      // Left unconverted: this single condition covers both read AND write.
      // materials:view (owner/manager/supervisor) would over-grant write/
      // approve rights beyond what the label implies; materials:approve
      // (owner/manager only) would regress supervisor's existing write
      // access. Needs the read/write split decided deliberately, not
      // conflated by a mechanical conversion.
      match /materialOrders/{id} { allow read, write: if ownerOrManager() || isSupervisor(); }
      // Staff can log a DO (materials:submit-do, Materials.jsx's Delivery
      // Orders tab) — anyStaff() already covers owner/manager/supervisor too,
      // so this is a pure widening from ownerOrManager()||isSupervisor().
      // Verify-status is only exposed in the UI to materials:approve holders;
      // like sitePhotos/notes elsewhere, that's a UI-level gate, not a
      // separate rules-level write restriction.
      match /deliveryOrders/{id} { allow read, write: if anyStaff(); }
      match /materials/{id}      { allow read, write: if ownerOrManager() || isSupervisor(); }

      // HSE / site subcollections — internal + assigned subcons
      function assignedToProject(pid) {
        return get(/databases/$(database)/documents/projects/$(pid)).data.assignedTeams.hasAny([myTeam()]);
      }
      match /permits/{id} {
        // read: left unconverted, same anyStaff()/subcon-scope reasoning as above
        allow read:  if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
        // write has no subcon branch at all — clean match to approve:permits
        allow write: if hasPerm('approve:permits');
      }
      match /toolboxMeetings/{id} {
        allow read:  if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
        // write has no subcon branch at all — clean match to toolbox:manage
        allow write: if hasPerm('toolbox:manage');
      }
      // Pure anyStaff() with no subcon branch at all — exact match to incidents:view
      match /incidents/{id}  { allow read, write: if hasPerm('incidents:view'); }
      // Snags are directed to the sub-con team handling the block, so an
      // assigned sub-con may read/log/update snags for their own team only.
      match /snags/{id} {
        allow read:   if anyStaff()
          || ((isSubconAdmin() || isSubcon()) && resource.data.assignedTeam == myTeam());
        allow create: if anyStaff()
          || ((isSubconAdmin() || isSubcon()) && request.resource.data.assignedTeam == myTeam());
        allow update: if anyStaff()
          || ((isSubconAdmin() || isSubcon()) && resource.data.assignedTeam == myTeam());
        allow delete: if ownerOrManager();
      }
      match /sitePhotos/{id} {
        allow read:  if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
        allow write: if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
      }

      // Notes — a timestamped discussion/change log, same audience as
      // sitePhotos (internal + assigned subcons). Append-only: no edits
      // once posted, and only owner/manager can remove a note (moderation,
      // not general editing) — keeps the log trustworthy as a running record.
      match /notes/{id} {
        allow read:   if anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId));
        allow create: if (anyStaff() || ((isSubconAdmin() || isSubcon()) && assignedToProject(projectId)))
          && request.resource.data.authorId == uid();
        allow update: if false;
        allow delete: if ownerOrManager();
      }
    }

    // ── WORKERS ────────────────────────────────────────────────────────────
    match /workers/{workerId} {
      // linkedUserId lets the worker's own login see their own record (certs,
      // photo) from Profile's "My Documents" — set when an admin links an
      // existing worker to a user account (see WorkerModal.jsx).
      allow read: if signedIn() && (
        ownerOrManager() || isSupervisor() ||
        (isSubconAdmin() && resource.data.team == myTeam()) ||
        resource.data.linkedUserId == uid()
      );
      allow create: if ownerOrManager()
        || (isSubconAdmin() && request.resource.data.team == myTeam());
      allow update: if ownerOrManager()
        // same team-immutability guard as the users rule — a subcon-admin
        // can edit their own workers but not move them to another team.
        || (isSubconAdmin() && resource.data.team == myTeam()
            && request.resource.data.team == resource.data.team);
      allow delete: if ownerOrManager();
    }

    // ── ANNOUNCEMENTS ──────────────────────────────────────────────────────
    match /announcements/{annId} {
      allow read: if signedIn();
      // Owner/manager can post anything; signed-in users can post system
      // notifications (leave requests etc.) targeted to management only.
      // Audience is now a list (bulletins can target several groups at
      // once) — system notifications always write it as the single-item
      // ['management'] list.
      allow create: if hasPerm('manage:announcements')
        || (signedIn()
            && request.resource.data.isSystemNotification == true
            && request.resource.data.audience == ['management']);
      allow update: if hasPerm('manage:announcements')
        // Any signed-in user may add their own userId to readBy (acknowledge)
        || (signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
      allow delete: if hasPerm('manage:announcements');
    }

    // ── RA LIBRARY ─────────────────────────────────────────────────────────
    match /raLibrary/{raId} {
      allow read:  if signedIn();
      allow write: if ownerOrManager();
    }

    // ── APP CONFIG (team groups, certificate types) ────────────────────────
    match /appConfig/{docId} {
      allow read:  if signedIn();
      allow write: if ownerOrManager();
    }

    // ── ACCESS LEVELS ──────────────────────────────────────────────────────
    // Defining/editing levels is never delegable via the permission system
    // itself — hard-coded owner/manager only, to prevent self-escalation
    // (someone with a grantable "manage access levels" permission could
    // otherwise grant themselves anything). Do not convert this to hasPerm().
    match /accessLevels/{levelId} {
      allow read:  if signedIn();
      allow write: if ownerOrManager();
    }

    // ── ATTENDANCE ─────────────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read: if signedIn() && (
        ownerOrManager() || isSupervisor() ||
        (isStaff()       && resource.data.userId == uid()) ||
        (isSubconAdmin() && resource.data.team   == myTeam()) ||
        (isSubcon()      && resource.data.userId == uid())
      );
      // create: left unconverted — the admin-override branch here is
      // ownerOrManager() only (no supervisor), narrower than
      // attendance:manage; converting would over-grant create rights.
      allow create: if signedIn() && (request.resource.data.userId == uid() || ownerOrManager());
      // update: role-component matches attendance:manage exactly
      allow update: if hasPerm('attendance:manage')
        || resource.data.userId == uid();
      allow delete: if ownerOrManager();
    }

    // ── SITE AUDITS (subcon spot checks) ──────────────────────────────────
    // Previously unruled (default-deny), which silently broke the Subcon
    // Audit page after bootstrap closed. Internal management feature only:
    // records name unregistered workers found on site, so worker roles have
    // no business reading them. Audits are point-in-time records — no
    // client-side edit or delete.
    match /siteAudits/{auditId} {
      allow read:   if ownerOrManager() || isSupervisor();
      allow create: if (ownerOrManager() || isSupervisor())
        && request.resource.data.conductedBy == uid();
      allow update, delete: if false;
    }

    // ── LEAVE ──────────────────────────────────────────────────────────────
    match /leaveApplications/{id} {
      // role-component matches leave:approve exactly
      allow read: if signedIn() && (
        hasPerm('leave:approve') || resource.data.userId == uid()
      );
      // create: left unconverted — admin-override is ownerOrManager() only
      // (no supervisor), narrower than leave:approve.
      allow create: if signedIn() && (request.resource.data.userId == uid() || ownerOrManager());
      // Applicants may edit or cancel their own application while pending,
      // but cannot change its owner or self-approve it.
      // role-component matches leave:approve exactly
      allow update: if hasPerm('leave:approve')
        || (resource.data.userId == uid()
            && resource.data.status == 'pending'
            && request.resource.data.status in ['pending', 'cancelled']
            && request.resource.data.userId == resource.data.userId);
      allow delete: if ownerOrManager();
    }
    match /leaveEntitlements/{id} {
      // role-component matches leave:approve exactly
      allow read: if signedIn() && (
        hasPerm('leave:approve') || resource.data.userId == uid()
      );
      // matches LeaveManagement.jsx's leave:settings-gated Entitlements tab
      allow write: if hasPerm('leave:settings');
    }

    // ── PAYROLL ────────────────────────────────────────────────────────────
    match /payslips/{id} {
      allow read:  if ownerOrManager() || resource.data.userId == uid();
      // matches PayslipGenerator.jsx's salary:manage-payslips admin branch
      allow write: if hasPerm('salary:manage-payslips');
    }
    match /salaryConfig/{id} {
      // matches SalaryCalculator.jsx's salary:config-gated Pay Config tab
      allow read, write: if hasPerm('salary:config');
    }
    match /pettyCashClaims/{id} {
      // role-component matches pettycash:approve exactly
      allow read: if hasPerm('pettycash:approve')
        || resource.data.userId == uid();
      allow create: if signedIn() && (request.resource.data.userId == uid() || ownerOrManager());
      // Submitters may correct their own claim, or withdraw it, while it is
      // still pending — same shape as leaveApplications above — but cannot
      // change its owner, self-approve it, or touch it once reviewed.
      // role-component matches pettycash:approve exactly (was ownerOrManager(),
      // which silently denied supervisors an Approve button the UI showed them).
      allow update: if hasPerm('pettycash:approve')
        || (resource.data.userId == uid()
            && resource.data.status == 'pending'
            && request.resource.data.status in ['pending', 'cancelled']
            && request.resource.data.userId == resource.data.userId);
      allow delete: if ownerOrManager();
    }
  }
}
